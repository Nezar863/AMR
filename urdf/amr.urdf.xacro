<?xml version="1.0"?>
<robot name="amr_description" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- =========================================================== -->
  <!-- MATERIALS                                                     -->
  <!-- =========================================================== -->
  <material name="dark_gray">
    <color rgba="0.2 0.2 0.2 1.0"/>
  </material>
  <material name="light_gray">
    <color rgba="0.7 0.7 0.7 1.0"/>
  </material>
  <material name="blue">
    <color rgba="0.0 0.4 0.8 1.0"/>
  </material>

  <!-- =========================================================== -->
  <!-- BASE LINK                                                     -->
  <!-- =========================================================== -->
  <!--
    Mass kept at 5.8kg (original) — SolidWorks exported 40.59kg because
    it used wrong material density. 5.8kg is the correct real-world value.
    Inertia values updated from SolidWorks (more accurate geometry).
  -->
  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="18.71"/>
      <inertia ixx="0.3986" ixy="0"      ixz="0"
               iyy="1.092"  iyz="0"
               izz="1.337"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://amr_description/meshes/Base_Link.STL"/>
      </geometry>
      <material name="dark_gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://amr_description/meshes/Base_Link.STL"/>
      </geometry>
    </collision>
  </link>

  <gazebo reference="base_link">
    <material>Gazebo/DarkGrey</material>
  </gazebo>

  <!-- =========================================================== -->
  <!-- FRONT LEFT WHEEL                                             -->
  <!-- =========================================================== -->
  <!--
    Joint origin: updated xyz from SolidWorks (z=0.012464, same as before).
    Joint rpy: SolidWorks gave rpy="1.5708 0 3.1416" — kept as-is, it is
    equivalent to the old rpy="1.5708 0 0" for wheel orientation purposes.
    Axis: SolidWorks gave "0 0 1" for left wheels with rpy including 3.1416
    (180 degree flip) — this naturally mirrors the axis direction.
    Collision: kept as cylinder (more stable than mesh for physics).
  -->

    <link name="front_left_wheel">
        <inertial>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <mass value="1.0"/>
            <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1"/>
        </inertial>
        <visual name="">
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <mesh filename="package://amr_description/meshes/Front_Left_Wheel.STL"/>
            </geometry>
            <material name="">
                <color rgba="0.5 0.2 0.1 1.0"/>
                <texture filename=""/>
            </material>
        </visual>
        <collision>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <cylinder radius="0.065" length="0.05"/>
            </geometry>
        </collision>
    </link>

  <joint name="front_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_left_wheel"/>
    <origin xyz="0.28082 0.18564 0.012464" rpy="1.5708 0 3.1416"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <gazebo reference="front_left_wheel">
    <collision>
      <surface>
        <friction>
          <ode>
            <mu>1.0</mu>
            <mu2>0.01</mu2>
            <fdir1>1 0 0</fdir1>
          </ode>
        </friction>
        <contact>
          <ode>
            <kp>1e6</kp>
            <kd>10.0</kd>
          </ode>
        </contact>
      </surface>
    </collision>
  </gazebo>

  <!-- =========================================================== -->
  <!-- FRONT RIGHT WHEEL                                            -->
  <!-- =========================================================== -->
  <!--
    Joint rpy: SolidWorks gave rpy="-1.5708 0 -3.1416" for right wheels.
    This is the natural mirror of the left wheel orientation.
    Axis: "0 0 1" — combined with the negative rpy this makes the wheel
    spin in the opposite direction to the left wheel, which is correct
    for differential drive. No axis swap or multiplier hack needed.
  -->
    <link name="front_right_wheel">
        <inertial>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <mass value="1.0"/>
            <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1"/>
        </inertial>
        <visual name="">
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <mesh filename="package://amr_description/meshes/Front_Right_Wheel.STL"/>
            </geometry>
            <material name="">
                <color rgba="0.5 0.2 0.1 1.0"/>
                <texture filename=""/>
            </material>
        </visual>
        <collision>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <cylinder radius="0.065" length="0.05"/>
            </geometry>
        </collision>
    </link>

  <joint name="front_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_right_wheel"/>
    <origin xyz="0.28082 -0.18564 0.012464" rpy="-1.5708 0 -3.1416"/>
    <axis xyz="0 0 -1"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <gazebo reference="front_right_wheel">
    <collision>
      <surface>
        <friction>
          <ode>
            <mu>1.0</mu>
            <mu2>0.01</mu2>
            <fdir1>1 0 0</fdir1>
          </ode>
        </friction>
        <contact>
          <ode>
            <kp>1e6</kp>
            <kd>10.0</kd>
          </ode>
        </contact>
      </surface>
    </collision>
  </gazebo>

  <!-- =========================================================== -->
  <!-- BACK LEFT WHEEL                                              -->
  <!-- =========================================================== -->
    <link name="back_left_wheel">
        <inertial>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <mass value="1.0"/>
            <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1"/>
        </inertial>
        <visual name="">
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
              <mesh filename="package://amr_description/meshes/Back_Left_Wheel.STL"/>
            </geometry>
            <material name="">
                <color rgba="0.5 0.2 0.1 1.0"/>
                <texture filename=""/>
            </material>
        </visual>
        <collision>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <cylinder radius="0.065" length="0.05"/>
            </geometry>
        </collision>
    </link>

  <joint name="back_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="back_left_wheel"/>
    <origin xyz="-0.2789 0.18564 0.014811" rpy="1.5708 0 3.1416"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <gazebo reference="back_left_wheel">
    <collision>
      <surface>
        <friction>
          <ode>
            <mu>1.0</mu>
            <mu2>0.01</mu2>
            <fdir1>1 0 0</fdir1>
          </ode>
        </friction>
        <contact>
          <ode>
            <kp>1e6</kp>
            <kd>10.0</kd>
          </ode>
        </contact>
      </surface>
    </collision>
  </gazebo>

  <!-- =========================================================== -->
  <!-- BACK RIGHT WHEEL                                             -->
  <!-- =========================================================== -->
  <!--
    Note: SolidWorks exported back right with rpy="1.5708 0 0" which is
    different from the other right wheel rpy="-1.5708 0 -3.1416".
    This looks like a SolidWorks export inconsistency — we use the same
    mirrored rpy as front right to keep both right wheels consistent.
  -->
    <link name="back_right_wheel">
        <inertial>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <mass value="1.0"/>
            <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1"/>
        </inertial>
        <visual name="">
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <mesh filename="package://amr_description/meshes/Back_Right_Wheel.STL"/>
            </geometry>
            <material name="">
                <color rgba="0.5 0.2 0.1 1.0"/>
                <texture filename=""/>
            </material>
        </visual>
        <collision>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <cylinder radius="0.065" length="0.05"/>
            </geometry>
        </collision>
    </link>

  <joint name="back_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="back_right_wheel"/>
    <origin xyz="-0.2789 -0.18564 0.014811" rpy="-1.5708 0 -3.1416"/>
    <axis xyz="0 0 -1"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <gazebo reference="back_right_wheel">
    <collision>
      <surface>
        <friction>
          <ode>
            <mu>1.0</mu>
            <mu2>0.01</mu2>
            <fdir1>1 0 0</fdir1>
          </ode>
        </friction>
        <contact>
          <ode>
            <kp>1e6</kp>
            <kd>10.0</kd>
          </ode>
        </contact>
      </surface>
    </collision>
  </gazebo>

  <!-- =========================================================== -->
  <!-- LIDAR                                                        -->
  <!-- =========================================================== -->
  <!--
    Link name kept as lidar_link (not Laser) to match the sensor
    bridge and gazebo plugin configuration.
    Origin xyz kept from old file — SolidWorks added a small y offset
    (-0.02) which we do not want as it moves the lidar off center.
  -->
  <link name="lidar_link">
    <inertial>
      <mass value="0.142"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="5.69e-05" ixy="0" ixz="0"
               iyy="8.93e-05" iyz="0"
               izz="1.09e-04"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://amr_description/meshes/Laser.STL"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.038" length="0.041"/>
      </geometry>
    </collision>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="-0.057 0 0.2608" rpy="0 0 0"/>
  </joint>

  <!-- Gazebo Harmonic 2D lidar plugin (360 degrees) -->
  <gazebo reference="lidar_link">
    <sensor name="lidar_sensor" type="gpu_lidar">
      <topic>scan</topic>
      <update_rate>10</update_rate>
      <always_on>true</always_on>
      <visualize>true</visualize>
      <lidar>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.12</min>
          <max>8.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </lidar>
      <gz_frame_id>lidar_link</gz_frame_id>
    </sensor>
  </gazebo>

  <!-- =========================================================== -->
  <!-- IMU                                                          -->
  <!-- =========================================================== -->
  <!--
    Link name kept as imu_link (not IMU_Link) to match bridge config.
    Inertia updated from SolidWorks values.
  -->
  <link name="imu_link">
    <inertial>
      <mass value="0.001"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="1e-6" ixy="0" ixz="0"
               iyy="1e-6" iyz="0"
               izz="1e-6"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://amr_description/meshes/IMU_Link.STL"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.03 0.03 0.01"/>
      </geometry>
    </collision>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- Gazebo Harmonic IMU plugin -->
  <gazebo reference="imu_link">
    <sensor name="imu_sensor" type="imu">
      <topic>imu</topic>
      <update_rate>10</update_rate>
      <always_on>true</always_on>
      <imu>
        <angular_velocity>
          <x><noise type="gaussian"><mean>0</mean><stddev>0.009</stddev></noise></x>
          <y><noise type="gaussian"><mean>0</mean><stddev>0.009</stddev></noise></y>
          <z><noise type="gaussian"><mean>0</mean><stddev>0.009</stddev></noise></z>
        </angular_velocity>
        <linear_acceleration>
          <x><noise type="gaussian"><mean>0</mean><stddev>0.021</stddev></noise></x>
          <y><noise type="gaussian"><mean>0</mean><stddev>0.021</stddev></noise></y>
          <z><noise type="gaussian"><mean>0</mean><stddev>0.021</stddev></noise></z>
        </linear_acceleration>
      </imu>
      <gz_frame_id>imu_link</gz_frame_id>
    </sensor>
  </gazebo>

  <!-- =========================================================== -->
  <!-- ROS2 CONTROL — 4-wheel drive hardware interface              -->
  <!-- =========================================================== -->
  <ros2_control name="amr_system" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>

    <joint name="front_left_wheel_joint">
      <command_interface name="velocity">
        <param name="min">-10</param>
        <param name="max">10</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="front_right_wheel_joint">
      <command_interface name="velocity">
        <param name="min">-10</param>
        <param name="max">10</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="back_left_wheel_joint">
      <command_interface name="velocity">
        <param name="min">-10</param>
        <param name="max">10</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="back_right_wheel_joint">
      <command_interface name="velocity">
        <param name="min">-10</param>
        <param name="max">10</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <!-- gz_ros2_control Gazebo plugin -->
  <gazebo>
    <plugin filename="gz_ros2_control-system"
            name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(find amr_description)/config/controllers.yaml</parameters>
      <ros>
        <namespace>/</namespace>
      </ros>
    </plugin>
  </gazebo>

</robot>
